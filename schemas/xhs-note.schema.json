{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "XhsNote",
  "type": "object",
  "required": [
    "note_id",
    "url",
    "title",
    "query",
    "first_seen_at",
    "last_seen_at",
    "crawl_source"
  ],
  "properties": {
    "note_id": { "type": "string" },
    "url": { "type": "string" },
    "title": { "type": ["string", "null"] },
    "query": { "type": "string" },
    "first_seen_at": { "type": "string" },
    "last_seen_at": { "type": "string" },
    "crawl_source": { "type": "string" },
    "content": { "type": ["string", "null"] },
    "detail_fetched_at": { "type": ["string", "null"] },
    "detail_error_runs": { "type": ["integer", "null"] },
    "detail_last_error": { "type": ["string", "null"] },
    "detail_next_attempt_after": { "type": ["string", "null"] },
    "interview_questions": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    },
    "comments": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "properties": {
          "author": { "type": ["string", "null"] },
          "content": { "type": ["string", "null"] },
          "likes": { "type": ["string", "number", "null"] },
          "time": { "type": ["string", "null"] }
        }
      }
    },
    "comment_count": { "type": ["integer", "null"] },
    "comment_error_runs": { "type": ["integer", "null"] },
    "comment_last_error": { "type": ["string", "null"] },
    "comment_next_attempt_after": { "type": ["string", "null"] },
    "seller_flag": { "type": ["boolean", "null"] },
    "seller_tags": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    },
    "seller_confidence": { "type": ["number", "null"] }
  }
}
